# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Only needed server-side (migrations, admin tasks) — never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used by local Supabase CLI (supabase db push, supabase gen types, etc.)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# GitHub Actions secrets for migrate.yml (set these in repo Settings > Secrets, not in .env.local)
# SUPABASE_DEV_DB_URL=postgresql://postgres:...@db.[dev-project-ref].supabase.co:5432/postgres
# SUPABASE_PROD_DB_URL=postgresql://postgres:...@db.[prod-project-ref].supabase.co:5432/postgres
